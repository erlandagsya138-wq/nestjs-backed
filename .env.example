# .env.development.local

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
APP_BASE_URL=http://10.20.27.106:3001

# ── Database (MySQL) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=capstone_project_db

# ── AI Microservice ───────────────────────────────────────────
FASTAPI_BASE_URL=http://10.20.27.106:8000
FASTAPI_API_KEY=dk_live_secret_key_here

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_ISSUER=capstone-backend
JWT_AUDIENCE=capstone-client

# ── Storage ───────────────────────────────────────────────────
# Switch provider: 'local' atau 's3'
STORAGE_PROVIDER=local

# Local Storage
STORAGE_LOCAL_DIR=uploads

# AWS S3 (aktif jika STORAGE_PROVIDER=s3)
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=durian-classification-bucket
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_CLOUDFRONT_URL=https://your_cloudfront_distribution_url.cloudfront.net

# ── Market Intelligence ───────────────────────────────────────
# Secret untuk verifikasi HMAC-SHA256 dari Market Intelligence Agent (Python).
# Harus sama persis dengan nilai NESTJS_INTERNAL_API_KEY di sisi agent.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NESTJS_INTERNAL_API_KEY=mi_dev_your_generated_key_here
